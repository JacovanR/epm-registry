{
  "library": "Enterprise Ultimate Performance Pack",
  "version": "1.0",
  "description": "Comprehensive enterprise KPI, IDP and Training template library supporting 500+ KPIs across all departments.",

  "rolePacks":[

    {
      "role":"Call Center Agent",

      "kpis":[
        {"id":"cc_calls_handled","name":"Calls Handled","metric":"number","target":1200},
        {"id":"cc_average_handle_time","name":"Average Handle Time","metric":"minutes","target":5},
        {"id":"cc_first_call_resolution","name":"First Call Resolution","metric":"percentage","target":85},
        {"id":"cc_customer_satisfaction","name":"Customer Satisfaction Score","metric":"rating","target":4},
        {"id":"cc_adherence","name":"Schedule Adherence","metric":"percentage","target":95}
      ],

      "training":[
        {"id":"customer_service_excellence","title":"Customer Service Excellence"},
        {"id":"call_handling_mastery","title":"Professional Call Handling"},
        {"id":"conflict_resolution","title":"Handling Difficult Customers"}
      ],

      "idpGoals":[
        {"id":"improve_customer_interaction","goal":"Improve customer communication"},
        {"id":"reduce_call_time","goal":"Improve call handling efficiency"}
      ]
    },

    {
      "role":"Call Center Team Leader",

      "kpis":[
        {"id":"team_sales_performance","name":"Team Sales Performance","metric":"percentage","target":100},
        {"id":"team_quality_score","name":"Team Quality Score","metric":"percentage","target":90},
        {"id":"team_attendance","name":"Team Attendance Rate","metric":"percentage","target":95},
        {"id":"team_kpi_achievement","name":"Team KPI Achievement","metric":"percentage","target":85}
      ],

      "training":[
        {"id":"leadership_basics","title":"Leadership Fundamentals"},
        {"id":"coaching_agents","title":"Coaching and Mentoring Agents"}
      ],

      "idpGoals":[
        {"id":"improve_team_leadership","goal":"Improve leadership capability"},
        {"id":"improve_coaching","goal":"Improve coaching and mentoring skills"}
      ]
    },

    {
      "role":"Marketing Specialist",

      "kpis":[
        {"id":"marketing_campaign_roi","name":"Campaign ROI","metric":"percentage","target":150},
        {"id":"marketing_lead_generation","name":"Leads Generated","metric":"number","target":1000},
        {"id":"marketing_conversion_rate","name":"Lead Conversion Rate","metric":"percentage","target":10},
        {"id":"marketing_engagement","name":"Digital Engagement Rate","metric":"percentage","target":20}
      ],

      "training":[
        {"id":"digital_marketing_strategy","title":"Digital Marketing Strategy"},
        {"id":"analytics_mastery","title":"Marketing Analytics"}
      ],

      "idpGoals":[
        {"id":"improve_campaign_strategy","goal":"Improve campaign strategy skills"},
        {"id":"improve_analytics","goal":"Improve data analytics capability"}
      ]
    },

    {
      "role":"IT Manager",

      "kpis":[
        {"id":"it_incident_resolution","name":"Incident Resolution Time","metric":"hours","target":8},
        {"id":"it_system_uptime","name":"System Uptime","metric":"percentage","target":99.9},
        {"id":"it_project_delivery","name":"Projects Delivered On Time","metric":"percentage","target":90},
        {"id":"it_security_incidents","name":"Security Incidents","metric":"number","target":0}
      ],

      "training":[
        {"id":"cybersecurity_leadership","title":"Cybersecurity Leadership"},
        {"id":"cloud_architecture","title":"Enterprise Cloud Architecture"}
      ],

      "idpGoals":[
        {"id":"improve_security_strategy","goal":"Improve cybersecurity leadership"},
        {"id":"improve_cloud_strategy","goal":"Improve cloud strategy capability"}
      ]
    },

    {
      "role":"Compliance Officer",

      "kpis":[
        {"id":"compliance_audit_score","name":"Audit Score","metric":"percentage","target":95},
        {"id":"regulatory_breaches","name":"Regulatory Breaches","metric":"number","target":0},
        {"id":"policy_compliance_rate","name":"Policy Compliance Rate","metric":"percentage","target":98}
      ],

      "training":[
        {"id":"regulatory_frameworks","title":"Regulatory Compliance Frameworks"},
        {"id":"risk_management","title":"Enterprise Risk Management"}
      ],

      "idpGoals":[
        {"id":"improve_regulatory_knowledge","goal":"Improve regulatory expertise"},
        {"id":"improve_risk_assessment","goal":"Improve risk assessment capability"}
      ]
    }

  ]
}
